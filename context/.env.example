# Environment for the divide-and-conquer context store.
#   cp .env.example .env   # .env is gitignored — put real values only there
# Keep endpoints/keys out of the repo (open-source hygiene).

# Postgres + pgvector connection (requires pgvector >= 0.5 for the HNSW index).
DNC_PG_DSN=postgresql:///dnc_context

# Embedding model, served through LiteLLM. Point DNC_EMBED_BASE at whichever backend
# won the tools/bench_embed.py comparison (S3 GPU node, 9700T CPU, or DeepInfra).
DNC_EMBED_BASE=http://localhost:4000/v1
DNC_EMBED_MODEL=embed:qwen3
DNC_EMBED_DIM=1024
# "none" for self-host; a real key ONLY when DNC_EMBED_BASE is a vendor like DeepInfra.
DNC_EMBED_KEY=none
